[include]
	# Personal git identity (name + email) — gitignored, must be created manually
	# Create .devcontainer/gitconfig.personal with:
	#   [user]
	#       name = Claude Sonnet 4.5
	#       email = you+claudecode@example.com
	path = /workspace/.devcontainer/gitconfig.personal

[pull]
	rebase = false

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	default = current

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = false

[merge]
	conflictstyle = diff3
