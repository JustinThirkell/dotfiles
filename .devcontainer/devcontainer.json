{
  "name": "Claude Code Sandbox - ${localWorkspaceFolderBasename}",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0"
    }
  },
  "runArgs": ["--cap-add=NET_ADMIN", "--cap-add=NET_RAW"],
  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code", "biomejs.biome", "eamodio.gitlens"],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": { "path": "bash", "icon": "terminal-bash" },
          "zsh": { "path": "zsh" }
        }
      }
    }
  },
  "remoteUser": "devcontainer",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/devcontainer/.claude,type=volume"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/devcontainer/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "DEVCONTAINER_USE_GITHUB_DEPLOY_KEY": "${localEnv:DEVCONTAINER_USE_GITHUB_DEPLOY_KEY:}",
    "DEBUG_DEVCONTAINER": "true"
  },
  "remoteEnv": {
    "SSH_AUTH_SOCK": "${localEnv:DEVCONTAINER_USE_GITHUB_DEPLOY_KEY:${localEnv:SSH_AUTH_SOCK}}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "/workspace/.devcontainer/scripts/post-create-command.sh",
  "postStartCommand": "/workspace/.devcontainer/scripts/post-start-command.sh",
  "postAttachCommand": "/workspace/.devcontainer/scripts/post-attach-command.sh",
  "waitFor": "postStartCommand"
}
